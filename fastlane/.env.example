# Copy to fastlane/.env (gitignored) for local TestFlight uploads

# Apple Developer
APPLE_ID=your-apple-id@email.com
DEVELOPMENT_TEAM_ID=TM2WG7HH96
APP_STORE_CONNECT_TEAM_ID=your_asc_team_id

# App Store Connect API key (Users and Access → Keys → App Store Connect API)
APP_STORE_CONNECT_API_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APP_STORE_CONNECT_API_KEY_CONTENT=BASE64_ENCODED_P8_CONTENT
APP_STORE_CONNECT_API_KEY_IS_BASE64=true

# TestFlight options
BUMP_BUILD=true
SKIP_WAIT_FOR_PROCESSING=true
DISTRIBUTE_EXTERNAL=false
# TESTFLIGHT_GROUPS=Internal Testers,Beta Testers
# TESTFLIGHT_CHANGELOG=Beta notes for testers
NOTIFY_EXTERNAL_TESTERS=false
