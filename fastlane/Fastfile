# Fastlane — TestFlight & App Store distribution
# Docs: https://docs.fastlane.tools/actions/upload_to_testflight/

default_platform(:ios)

APP_IDENTIFIER = "wcs.WCS-GoldTest"
SCHEME = "WCS-GoldTest"
XCODEPROJ = "WCS-GoldTest.xcodeproj"
ASC_APP_ID = "6770415355" # App Store Connect → App Information → Apple ID

def asc_api_key
  return nil unless ENV["APP_STORE_CONNECT_API_KEY_ID"]

  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
    is_key_content_base64: ENV.fetch("APP_STORE_CONNECT_API_KEY_IS_BASE64", "true") == "true",
    in_house: false
  )
end

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Run unit tests on simulator"
  lane :test do
    run_tests(
      project: XCODEPROJ,
      scheme: SCHEME,
      device: "iPhone 16",
      code_coverage: true
    )
  end

  desc "Increment build number from latest TestFlight build"
  lane :bump_build do
    api_key = asc_api_key
    if api_key
      latest = latest_testflight_build_number(
        app_identifier: APP_IDENTIFIER,
        api_key: api_key
      )
      increment_build_number(
        build_number: (latest + 1).to_s,
        xcodeproj: XCODEPROJ
      )
    else
      UI.important("No ASC API key — incrementing build number locally by 1")
      increment_build_number(xcodeproj: XCODEPROJ)
    end
    UI.success("Build number set to #{get_build_number(xcodeproj: XCODEPROJ)}")
  end

  desc "Build Release IPA for App Store / TestFlight"
  lane :build_release do
    bump_build if ENV.fetch("BUMP_BUILD", "true") == "true"

    api_key = asc_api_key

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      export_options: "./fastlane/ExportOptions.plist",
      output_directory: "./build",
      output_name: "WCS-GoldTest",
      clean: true,
      include_bitcode: false,
      api_key: api_key,
      xcargs: "-allowProvisioningUpdates"
    )
  end

  desc "Upload to TestFlight (build + upload)"
  lane :beta do
    api_key = asc_api_key

    build_release

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      apple_id: ASC_APP_ID,
      skip_waiting_for_build_processing: ENV.fetch("SKIP_WAIT_FOR_PROCESSING", "true") == "true",
      distribute_external: ENV.fetch("DISTRIBUTE_EXTERNAL", "false") == "true",
      groups: ENV["TESTFLIGHT_GROUPS"]&.split(",")&.map(&:strip),
      changelog: ENV.fetch("TESTFLIGHT_CHANGELOG") { default_changelog_text },
      notify_external_testers: ENV.fetch("NOTIFY_EXTERNAL_TESTERS", "false") == "true"
    )

    UI.success("Uploaded to TestFlight for #{APP_IDENTIFIER}")
    UI.message("Manage testers: https://appstoreconnect.apple.com/apps/#{ASC_APP_ID}/testflight")
  end

  desc "Upload existing IPA at build/WCS-GoldTest.ipa"
  lane :upload_only do
    upload_to_testflight(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      apple_id: ASC_APP_ID,
      ipa: "./build/WCS-GoldTest.ipa",
      skip_waiting_for_build_processing: true,
      changelog: ENV.fetch("TESTFLIGHT_CHANGELOG", default_changelog)
    )
  end

  desc "Refresh TestFlight build metadata in App Store Connect"
  lane :beta_metadata do
    deliver(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      app_version: get_version_number(xcodeproj: XCODEPROJ),
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      submit_for_review: false
    )
  end

end

def default_changelog_text
  <<~NOTES
    WCS Gold Test beta build
    • Gold scan workflow with BLE probe (mock in simulator)
    • Vault, reports, admin access & TestFlight entitlements
    • Screening estimates only — not laboratory certification
  NOTES
end
